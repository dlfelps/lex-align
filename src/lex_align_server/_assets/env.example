# lex-align server configuration. Copy to `.env` and edit as needed.

# Single-user mode (default): no API keys, every request recorded as
# `requester="anonymous"`. Set to `true` for organization mode.
AUTH_ENABLED=false

# Server bind. The compose file maps 127.0.0.1:8765 → container:8765.
# Inside the container we always bind 0.0.0.0:8765.
BIND_HOST=0.0.0.0
BIND_PORT=8765

# CVE threshold as a fraction of CVSS 10. Default 0.9 = deny CVSS >= 9.0.
CVE_THRESHOLD=0.9
